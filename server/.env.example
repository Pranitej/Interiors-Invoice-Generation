# ─── Database ────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/craftquote_db
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/craftquote_db
MONGO_URI=mongodb://localhost:27017/craftquote_db

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# Frontend origin allowed by CORS (no trailing slash)
# Local:      http://localhost:5173
# Production: https://pmsoftwaresolutions.com
CORS_ORIGIN=http://localhost:5173

# Set to true when running behind a reverse proxy (e.g. Nginx on VPS)
TRUST_PROXY=false

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-min-64-chars

# ─── Super Admin ─────────────────────────────────────────────────────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=replace-with-strong-password

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=CraftQuote

# ─── Puppeteer / PDF ─────────────────────────────────────────────────────────
# Leave blank locally (uses Puppeteer's bundled Chrome)
# Set to /usr/bin/chromium on VPS / Docker (Coolify)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ─── Backups ─────────────────────────────────────────────────────────────────
# Set to true on VPS to enable nightly mongodump backups at 2am
BACKUP_ENABLED=false
# Directory where daily backup folders will be created (must be writable)
BACKUP_DIR=/backups
